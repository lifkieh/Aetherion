; Engine configuration file.
; AETHERION — Fase 0

config_version=5

[application]

config/name="Aetherion"
config/description="2D open-world sandbox action RPG — real WIB time, lunar sky, taming, crafting."
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoload/EventBus.gd"
Db="*res://autoload/Db.gd"
UiTheme="*res://autoload/UiTheme.gd"
GameClock="*res://autoload/GameClock.gd"
WorldState="*res://autoload/WorldState.gd"
PlayerData="*res://autoload/PlayerData.gd"
Economy="*res://autoload/Economy.gd"
SaveManager="*res://autoload/SaveManager.gd"
Audio="*res://autoload/Audio.gd"
ScenarioManager="*res://autoload/ScenarioManager.gd"
Settings="*res://autoload/Settings.gd"
Achievements="*res://autoload/Achievements.gd"
QuestSystem="*res://autoload/QuestSystem.gd"
PhotoMode="*res://autoload/PhotoMode.gd"
FishingUI="*res://autoload/FishingUI.gd"
MusicDirector="*res://autoload/MusicDirector.gd"
ProjectilePool="*res://autoload/ProjectilePool.gd"
CombatFeel="*res://autoload/CombatFeel.gd"
ProfessionSystem="*res://autoload/ProfessionSystem.gd"
SafeZone="*res://autoload/SafeZone.gd"
CharGen="*res://autoload/CharGen.gd"
Stage="*res://autoload/Stage.gd"
Onboarding="*res://autoload/Onboarding.gd"
MiracleSystem="*res://autoload/MiracleSystem.gd"
Cutscene="*res://autoload/Cutscene.gd"
Chronicle="*res://autoload/Chronicle.gd"
ForestSpiritSystem="*res://autoload/ForestSpiritSystem.gd"
Keybinds="*res://autoload/Keybinds.gd"
AdvancedClass="*res://autoload/AdvancedClass.gd"
DebugOverlay="*res://autoload/DebugOverlay.gd"
Loc="*res://autoload/Loc.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

