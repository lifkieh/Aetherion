  "rules": {
    "fire": [
      {"desc": "Api padam di bawah air", "if": {"underwater": true}, "mult": 0.5},
      {"desc": "Target basah / hujan mengurangi api", "if": {"target_wet": true}, "mult": 0.7},
      {"desc": "Angin memasok oksigen", "if": {"wind_active": true}, "mult": 1.25}
    ],
    "lightning": [
      {"desc": "Konduksi lewat air: target basah +30% dan menyambar (chain)", "if": {"target_wet": true}, "mult": 1.3, "chain": true},
      {"desc": "Target grounded (Earth) kebal chain", "if": {"target_grounded": true}, "mult": 0.7, "chain": false}
    ],
    "ice": [
      {"desc": "Es meleleh di area panas", "if": {"hot_zone": true}, "mult": 0.7}
    ],
    "water": [
      {"desc": "Membasahi target (menerapkan status Wet)", "if": {}, "apply_status": "wet"}
    ],
    "wood": [
      {"desc": "Fotosintesis: siang hari regen/growth", "if": {"is_day": true}, "mult": 1.1}
    ],
    "darkness": [
      {"desc": "Kuat di malam / gua", "if": {"is_night": true}, "mult": 1.2}
    ],
    "light": [
      {"desc": "Terik siang memperkuat cahaya", "if": {"is_day": true}, "mult": 1.1}
    ],
    "star": [
      {"desc": "Kuat saat langit cerah malam", "if": {"is_night": true, "clear_sky": true}, "mult": 1.25},
      {"desc": "Mati rasa saat mendung", "if": {"overcast": true}, "mult": 0.7}
    ],
    "sun": [
      {"desc": "Puncak tengah hari", "if": {"solar_noon": true}, "mult": 1.3},
      {"desc": "Lemah di malam hari", "if": {"is_night": true}, "mult": 0.7}
    ],
    "moon": [
      {"desc": "Mengikuti fase bulan: purnama puncak", "if": {"full_moon": true}, "mult": 1.3},
      {"desc": "Lemah saat bulan baru", "if": {"new_moon": true}, "mult": 0.7}
    ]
  },
  "platformer_rules": {
    "wind": {"double_jump": true, "desc": "Infus Wind memberi lompatan ganda singkat."},
    "ice": {"freeze_puddle": true, "desc": "Infus Ice membekukan genangan air jadi pijakan padat."},
    "fire": {"melt_ice": true, "desc": "Api mencairkan es kembali jadi air."}
  },
  "combos": [
    {"a": "fire", "b": "wind", "result": "Firestorm", "element": "fire", "mult": 1.7, "desc": "Badai api menyapu — angin memasok oksigen."},
    {"a": "lightning", "b": "water", "result": "Thunder Rain", "element": "lightning", "mult": 1.6, "chain": true, "desc": "Hujan menyetrum semua yang basah."},
    {"a": "fire", "b": "water", "result": "Steam Burst", "element": "water", "mult": 1.3, "desc": "Uap panas — penguapan mengaburkan pandangan."},
    {"a": "fire", "b": "ice", "result": "Thermal Shock", "element": "fire", "mult": 1.9, "desc": "Ekspansi termal meretakkan target beku."},
    {"a": "ice", "b": "wind", "result": "Blizzard", "element": "ice", "mult": 1.5, "desc": "Badai salju memperlambat."},
    {"a": "water", "b": "wind", "result": "Typhoon", "element": "water", "mult": 1.6, "desc": "Topan menghempas."},
    {"a": "light", "b": "darkness", "result": "Eclipse", "element": "light", "mult": 1.8, "desc": "Gerhana — keseimbangan yang memusnahkan."},
    {"a": "earth", "b": "fire", "result": "Magma Surge", "element": "fire", "mult": 1.7, "desc": "Lelehan batu menerjang."},
    {"a": "star", "b": "void", "result": "Supernova", "element": "star", "mult": 2.4, "desc": "Ledakan bintang — lore akhir game."}
  ]
